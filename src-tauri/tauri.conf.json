{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "The Ball",
  "version": "0.1.4",
  "identifier": "com.theball.app",

  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "windows": [
      {
        "title": "The Ball",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "permissions": [
            "core:default",
            "core:webview:allow-internal-toggle-devtools",
            "updater:default",
            "process:default"
          ]
        }
      ]
    }
  },

  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA2QjQ4M0FBQTJGNEIwNUMKUldSY3NQU2lxb08wQmhPc3dkbnlKQjZhazZDcjFtU2VSSHVTZGdJbkgrUWEydnlWRGY5ZHZ6VnoK",
      "endpoints": [
        "https://github.com/dhollandermatthew-ctrl/theball/releases/latest/download/latest.json"
      ]
    }
  },

  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}